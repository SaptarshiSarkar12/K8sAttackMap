<configuration>
    <conversionRule conversionWord="cliPrefix" class="io.github.SaptarshiSarkar12.k8sattackmap.util.CliPrefixConverter" />
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%cliPrefix\n</pattern>
        </encoder>
    </appender>

    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>logs/k8s-attack-map.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>logs/k8s-attack-map.%d{yyyy-MM-dd}.log</fileNamePattern>
            <maxHistory>7</maxHistory>
            <totalSizeCap>50MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Logger for PDType1Font - only logs to file, not console to avoid cluttering console output
            with font fallback warnings -->
    <logger name="org.apache.pdfbox.pdmodel.font.PDType1Font" level="INFO" additivity="false">
        <appender-ref ref="FILE" />
    </logger>

    <!-- Logger for IOUtils - only logs to file, not console to avoid cluttering console output
            with warnings about inaccessible methods when running on Java 9+ -->
    <logger name="org.apache.pdfbox.io.IOUtils" level="INFO" additivity="false">
        <appender-ref ref="FILE" />
    </logger>

    <root level="INFO">
        <appender-ref ref="STDOUT" />
        <appender-ref ref="FILE" />
    </root>
</configuration>